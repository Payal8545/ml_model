{
  "manifest_version": 3,
  "name": "My Toxic Blur",
  "version": "1.0",
  "description": "Blurs toxic text using my local AI.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}